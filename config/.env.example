# n8n Easy Deploy Configuration

# n8n Settings
N8N_PORT=5678
N8N_ENCRYPTION_KEY=your_encryption_key_here

# Database Settings
DB_USER=n8n
DB_PASS=secret
DB_HOST=postgres
DB_PORT=5432
DB_NAME=n8n

# Redis Settings
REDIS_PASS=redissecret

# AWS Settings (if using S3 for backups)
AWS_BUCKET=your-s3-bucket-name

# Domain and Auto SSL Settings for Caddy
DOMAIN_NAME=example.com
LETSENCRYPT_EMAIL=you@example.com

# Update Interval (seconds)
UPDATE_INTERVAL=86400
